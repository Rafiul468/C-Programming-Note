        //sum_from_1_to_n


#include<stdio.h>
int main()
{
    int n;
    scanf("%d", &n);

    int sum = 0;

    for(int i=1; i<=n; i++){
        sum = sum+i;
    }
    printf("%d\n", sum);

    return 0;
}

