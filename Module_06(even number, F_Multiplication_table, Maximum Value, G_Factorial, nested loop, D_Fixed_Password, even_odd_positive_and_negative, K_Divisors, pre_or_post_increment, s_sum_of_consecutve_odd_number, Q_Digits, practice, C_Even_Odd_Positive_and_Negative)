            //C_Even_Odd_Positive_and_Negative

#include<stdio.h>
int main(){
    int n;
    int even=0,odd=0,positive=0,negative=0;
    scanf("%d",&n);

    for(int i=1;i<=n;i++){
        int x;
        scanf("%d\n", &x);
        if(x%2==0){
            even++;
        }
        else{
            odd++;
        }
        if(x>0){
            positive++;
        }
        else if(x<0){
            negative++;
        }
    }
    printf("Even: %d\n", even);
    printf("Odd: %d\n", odd);
    printf("Positive: %d\n", positive);
    printf("Negative: %d", negative);
    return 0;   
}
