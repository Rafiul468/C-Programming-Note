                        //if-else Ladder

#include<stdio.h>
int main()
{
    int tk;
    scanf("%d", &tk);

    if(tk>=100){
        printf("Burger khabo\n");   //if er code
    }
    else if(tk>=50){
        printf("Pizza khabo\n");   //else if er code
    }
    else{
        printf("kichui khabo na\n");  //else er code
    }

    return 0;
}

