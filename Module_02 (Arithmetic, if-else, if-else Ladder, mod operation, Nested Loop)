                //Arithmetic

#include<stdio.h>
int main()
{
    int a =10;
    int b =20;
    int sum = a + b;
    printf("%d\n", sum);

    int sub = a-b;
    printf("%d\n", sub);

    int mul = a*b;
    printf("%d\n", mul);

    int div = a/b;
    printf("%d\n", div);
    
    return 0;
}


